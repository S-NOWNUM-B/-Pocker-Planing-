# Backend
BACKEND_PORT=8000 # Порт для FastAPI
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/planning_poker # URL для подключения к PostgreSQL
JWT_SECRET_KEY=dev-secret-key-not-for-production # Секретный ключ для JWT (используйте более сложный ключ в продакшене)
JWT_ALGORITHM=HS256 # Алгоритм для JWT
ACCESS_TOKEN_EXPIRE_MINUTES=10080 # Время жизни токена (в минутах, 7 дней)

# Frontend
FRONTEND_PORT=5173 # Порт для Vite (React)
VITE_API_URL=http://localhost:8000 # URL для API (используется в React)

# Application
APP_NAME=Покер-планирование # Название приложения
ENVIRONMENT=development # Окружение (development, production, etc.)

# Demo Data
SEED_DEMO_DATA=true # Флаг для загрузки демо-данных при запуске
DEMO_USER_PASSWORD=DemoPass123! # Пароль для демо-пользователей (используйте более сложный пароль в продакшене)

# CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000 # Разрешенные источники для CORS (разделенные запятыми)
